# OpenAI / LLM
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.agentplatform.ru/v1
OPENAI_MODEL=openai/gpt-5-mini

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9004
KAFKA_TOPIC_EMAILS=email-extraction-tasks
KAFKA_CONSUMER_GROUP=email-extraction-workers

# Webhooks
# При локальном запуске без Docker укажите явные URL
# При запуске через docker compose TEST_WEBHOOK_URL переопределяется в compose файле
WEBHOOK_URL=https://your-crm.example.com/webhook
TEST_WEBHOOK_URL=http://localhost:9003/webhook-files

# Retry
MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=9002

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_CLEANUP_HOURS=24
